{
  "manifest_version": 3,
  "name": "PDF Master Dark Mode",
  "description": "Dark mode and visual filters for online and local PDFs",
  "version": "1.0",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "file:///*",
    "https://*/*.pdf"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-dark-mode": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "MacCtrl+Shift+D"
      },
      "description": "Toggle Dark Mode"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PDF Master Dark Mode",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*.pdf",
        "*://*/*.pdf?*",
        "file:///*.pdf",
        "file:///*.pdf?*"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}